# ─────────────────────────────────────────────────────────────────────────────
# Network Security Analytics Platform — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite (no setup needed). Swap to postgres:// for production.
DATABASE_URL=sqlite:///./network_security.db
# DATABASE_URL=postgresql://user:password@localhost:5432/network_security_db

# ── API Security ──────────────────────────────────────────────────────────────
# Left unset on purpose: if SECRET_KEY/ADMIN_PASSWORD aren't set, a random
# value is generated at startup and logged once. That's safe by default for
# local dev. For anything persistent (a real deployment, or local dev where
# you want tokens to survive a restart), uncomment and set your own —
# never reuse the values from this example file, they're public.
# SECRET_KEY=<a random 64-char string, e.g. `python -c "import secrets; print(secrets.token_hex(32))"`>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Comma-separated list of allowed origins for the dashboard/API. Never use "*".
CORS_ORIGINS=http://localhost:8501

# ── Default Admin User (created on first run) ─────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=<set your own — see note above, this is also left unset on purpose>

# ── MLflow Tracking ───────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=network_security_capstone

# ── Paths ─────────────────────────────────────────────────────────────────────
DATA_DIR=./data
MODELS_DIR=./models
REPORTS_DIR=./reports

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
